{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "The Black Pearl",
  "version": "0.1.0",
  "identifier": "com.matt.ghosty",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1423",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 18, "y": 23 },
        "backgroundColor": "#09090B"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "Entitlements.plist",
      "signingIdentity": "Developer ID Application: Matt Wisniewski (F6ZAL7ANAD)"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
